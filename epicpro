}

/* ════════════════════════════════════════════
   RUN
════════════════════════════════════════════ */
function run() {
  const btn = document.getElementById('run-btn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spin">⚙</span> Obliczam…';
  buildMonthTable();
  setTimeout(() => {
    try {
      const res = simulate();
      if (!res) { alert('Podaj historyczne tempo!'); return; }
      renderMain(res);
    } finally {
      btn.disabled = false;
      btn.innerHTML = '🎲 Uruchom symulację';
    }
  }, 40);
}

/* ════════════════════════════════════════════
   INIT
════════════════════════════════════════════ */
renderEpics();
buildMonthTable();
window.addEventListener('DOMContentLoaded', () => setTimeout(run, 60));
</script>
